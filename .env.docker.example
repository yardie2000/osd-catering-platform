# Copy this file to ".env" next to docker-compose.yml and fill in the real values
# from your .env.local. The ".env" file is gitignored — never commit it.
#
#   cp .env.docker.example .env   # then edit .env
#
# Values come from your Supabase project (Project Settings → API):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Tunnel token (Zero Trust → Networks → Tunnels → your tunnel).
# Required only when exposing the app via Cloudflare; leave empty for LAN-only.
CLOUDFLARE_TUNNEL_TOKEN=
